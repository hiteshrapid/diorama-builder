{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@diorama/engine": ["packages/engine/src"],
      "@diorama/plugins": ["packages/plugins/src"],
      "@diorama/cli": ["packages/cli/src"],
      "@diorama/ui": ["packages/ui/src"]
    }
  },
  "references": [
    { "path": "packages/engine" },
    { "path": "packages/plugins" },
    { "path": "packages/cli" },
    { "path": "packages/ui" }
  ]
}
